# =============================================================================
# VPN Platform - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y modifica los valores según tu configuración.
#
#   cp .env.example .env
#   nano .env
# =============================================================================

# ---------------------------------------------------------------------------
# DOMINIO Y SERVIDOR
# ---------------------------------------------------------------------------
# Tu dominio principal (ej: mivpn.com)
SERVER_DOMAIN=tudominio.com

# Email del administrador (usado para certificados Let's Encrypt)
ADMIN_EMAIL=admin@tudominio.com

# Zona horaria del servidor (Brasil)
TIMEZONE=America/Sao_Paulo

# ---------------------------------------------------------------------------
# WIREGUARD VPN
# ---------------------------------------------------------------------------
# IP pública o dominio del servidor VPN
WG_HOST=tudominio.com

# Puerto UDP de WireGuard (por defecto: 51820)
WG_PORT=51820

# DNS que usarán los clientes VPN (Pi-hole interno)
WG_DEFAULT_DNS=10.8.1.100

# IPs permitidas a través del túnel VPN
# 0.0.0.0/0 = todo el tráfico pasa por el VPN
WG_ALLOWED_IPS=0.0.0.0/0, ::/0

# Contraseña para el panel de administración de WireGuard (wg-easy)
# IMPORTANTE: Usa una contraseña fuerte de al menos 16 caracteres
WG_ADMIN_PASSWORD=CambiaEstaContraseña!Segura2024

# ---------------------------------------------------------------------------
# PI-HOLE DNS
# ---------------------------------------------------------------------------
# Contraseña para el panel de administración de Pi-hole
# IMPORTANTE: Usa una contraseña fuerte de al menos 16 caracteres
PIHOLE_PASSWORD=CambiaEstaContraseña!PiHole2024
